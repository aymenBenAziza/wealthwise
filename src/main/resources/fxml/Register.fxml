<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wealthwise.controllers.RegisterController"
      style="-fx-background-color: white;">

    <!-- ── LEFT: Form panel ─────────────────────────────────────────── -->
    <VBox alignment="CENTER" spacing="0"
          style="-fx-padding: 50 50; -fx-background-color: white;"
          HBox.hgrow="ALWAYS">

        <Label text="WEALTHWISE"
               style="-fx-font-size: 11; -fx-font-weight: bold;
                      -fx-text-fill: #185FA5; -fx-letter-spacing: 2;">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Label>

        <Label text="Creer un compte"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
        <Label text="Rejoignez WealthWise gratuitement"
               style="-fx-font-size: 13; -fx-text-fill: #888888;">
            <VBox.margin><Insets bottom="28"/></VBox.margin>
        </Label>

        <!-- Name -->
        <VBox spacing="4" maxWidth="340">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
            <Label text="Nom complet" style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
            <TextField fx:id="nameField" promptText="Ahmed Ben Ali" maxWidth="340"
                       style="-fx-pref-height: 38; -fx-font-size: 13;
                              -fx-background-radius: 8; -fx-border-radius: 8;
                              -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
            <Label fx:id="nameError" text=""
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="4" maxWidth="340">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
            <Label text="Email" style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
            <TextField fx:id="emailField" promptText="exemple@email.com" maxWidth="340"
                       style="-fx-pref-height: 38; -fx-font-size: 13;
                              -fx-background-radius: 8; -fx-border-radius: 8;
                              -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
            <Label fx:id="emailError" text=""
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="4" maxWidth="340">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
            <Label text="Mot de passe" style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
            <PasswordField fx:id="passwordField" promptText="Min. 6 caracteres" maxWidth="340"
                           style="-fx-pref-height: 38; -fx-font-size: 13;
                                  -fx-background-radius: 8; -fx-border-radius: 8;
                                  -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
            <Label fx:id="passwordError" text=""
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
        </VBox>

        <!-- Confirm password -->
        <VBox spacing="4" maxWidth="340">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
            <Label text="Confirmer le mot de passe"
                   style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
            <PasswordField fx:id="confirmField" promptText="••••••••" maxWidth="340"
                           style="-fx-pref-height: 38; -fx-font-size: 13;
                                  -fx-background-radius: 8; -fx-border-radius: 8;
                                  -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
            <Label fx:id="confirmError" text=""
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
        </VBox>

        <!-- Message label -->
        <Label fx:id="messageLabel" text="" wrapText="true" maxWidth="340">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Label>

        <!-- Register button -->
        <Button text="Creer mon compte" onAction="#handleRegister"
                maxWidth="340" prefHeight="42"
                style="-fx-background-color: #185FA5; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand;">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </Button>

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Deja un compte ?"
                   style="-fx-font-size: 12; -fx-text-fill: #888888;"/>
            <Button text="Se connecter" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #185FA5;
                           -fx-font-size: 12; -fx-cursor: hand;
                           -fx-border-color: transparent; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>

    <!-- ── RIGHT: Blue branding panel ──────────────────────────────── -->
    <VBox alignment="CENTER" spacing="16" prefWidth="380"
          style="-fx-background-color: #185FA5; -fx-padding: 60 40;">

        <Label text="WealthWise"
               style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Votre assistant financier personnel"
               wrapText="true"
               style="-fx-font-size: 14; -fx-text-fill: #B5D4F4;
                      -fx-text-alignment: center;">
            <VBox.margin><Insets bottom="32"/></VBox.margin>
        </Label>

        <VBox spacing="16">
            <VBox spacing="4">
                <Label text="Gratuit et securise"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Vos donnees restent sur votre machine"
                       style="-fx-font-size: 12; -fx-text-fill: #B5D4F4;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Tableaux de bord avances"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Graphiques et statistiques en temps reel"
                       style="-fx-font-size: 12; -fx-text-fill: #B5D4F4;"/>
            </VBox>
            <VBox spacing="4">
                <Label text="Intelligence Artificielle"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Conseils personnalises par IA Groq"
                       style="-fx-font-size: 12; -fx-text-fill: #B5D4F4;"/>
            </VBox>
        </VBox>

    </VBox>

</HBox>
