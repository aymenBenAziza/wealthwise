<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wealthwise.controllers.UserProfileController"
            style="-fx-background-color: #f4f5f7;">

    <!-- ── TOP BAR ──────────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #185FA5; -fx-padding: 14 28 14 28;">

            <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                <Label text="WEALTHWISE"
                       style="-fx-font-size: 11; -fx-font-weight: bold;
                              -fx-text-fill: #B5D4F4; -fx-letter-spacing: 2;"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button text="Tableau de bord" onAction="#goToDashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-font-size: 12;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14;"/>
                <Button text="Transactions" onAction="#goToTransactions"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                           -fx-text-fill: white; -fx-font-size: 12;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-padding: 6 14;"/>

                <Button text="Profil"
                        style="-fx-background-color: white; -fx-text-fill: #185FA5;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14;"/>
                <Button text="Deconnexion" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #B5D4F4;
                               -fx-font-size: 12; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 6 10; -fx-border-color: transparent;">
                    <HBox.margin><Insets left="8"/></HBox.margin>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ── BODY ─────────────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 28;">

                <!-- Page title -->
                <VBox spacing="4">
                    <Label text="Mon profil"
                           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
                    <Label text="Gerez vos informations personnelles et preferences"
                           style="-fx-font-size: 13; -fx-text-fill: #888888;"/>
                </VBox>

                <!-- Status message -->
                <Label fx:id="messageLabel" text="" wrapText="true"
                       style="-fx-font-size: 12; -fx-background-radius: 6; -fx-padding: 8 14;"/>

                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- ── LEFT COLUMN ─────────────────────────────── -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <!-- Section 1: Personal Info -->
                        <VBox spacing="14"
                              style="-fx-background-color: white;
                                     -fx-border-color: #eeeeee; -fx-border-width: 0.5;
                                     -fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-padding: 20 24;">

                            <Label text="Informations personnelles"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #222222;"/>

                            <!-- Avatar circle -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <Label fx:id="avatarLabel"
                                       style="-fx-min-width: 60; -fx-min-height: 60;
                                              -fx-max-width: 60; -fx-max-height: 60;
                                              -fx-background-color: #185FA5;
                                              -fx-background-radius: 30;
                                              -fx-text-fill: white; -fx-font-size: 22;
                                              -fx-font-weight: bold; -fx-alignment: center;"/>
                                <VBox spacing="2">
                                    <Label fx:id="userNameDisplay"
                                           style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
                                    <Label fx:id="userEmailDisplay"
                                           style="-fx-font-size: 12; -fx-text-fill: #888888;"/>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <!-- Name field -->
                            <VBox spacing="4">
                                <Label text="Nom complet"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <TextField fx:id="nameField"
                                           style="-fx-pref-height: 36; -fx-font-size: 13;
                                                  -fx-background-radius: 6; -fx-border-radius: 6;
                                                  -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                                <Label fx:id="nameError" text=""
                                       style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                            </VBox>

                            <!-- Email field -->
                            <VBox spacing="4">
                                <Label text="Adresse email"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <TextField fx:id="emailField"
                                           style="-fx-pref-height: 36; -fx-font-size: 13;
                                                  -fx-background-radius: 6; -fx-border-radius: 6;
                                                  -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                                <Label fx:id="emailError" text=""
                                       style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                            </VBox>

                            <Button text="Sauvegarder les informations"
                                    onAction="#handleSaveInfo"
                                    style="-fx-background-color: #185FA5;
                                           -fx-text-fill: white; -fx-font-size: 13;
                                           -fx-font-weight: bold; -fx-background-radius: 6;
                                           -fx-cursor: hand; -fx-padding: 10 20;"/>
                        </VBox>

                        <!-- Section 2: Change Password -->
                        <VBox spacing="14"
                              style="-fx-background-color: white;
                                     -fx-border-color: #eeeeee; -fx-border-width: 0.5;
                                     -fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-padding: 20 24;">

                            <Label text="Changer le mot de passe"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #222222;"/>

                            <VBox spacing="4">
                                <Label text="Mot de passe actuel"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <PasswordField fx:id="currentPasswordField"
                                               style="-fx-pref-height: 36; -fx-font-size: 13;
                                                     -fx-background-radius: 6; -fx-border-radius: 6;
                                                     -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                                <Label fx:id="currentPwdError" text=""
                                       style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Nouveau mot de passe"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <PasswordField fx:id="newPasswordField"
                                               style="-fx-pref-height: 36; -fx-font-size: 13;
                                                     -fx-background-radius: 6; -fx-border-radius: 6;
                                                     -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                                <Label fx:id="newPwdError" text=""
                                       style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Confirmer le nouveau mot de passe"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <PasswordField fx:id="confirmPasswordField"
                                               style="-fx-pref-height: 36; -fx-font-size: 13;
                                                     -fx-background-radius: 6; -fx-border-radius: 6;
                                                     -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                                <Label fx:id="confirmPwdError" text=""
                                       style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                            </VBox>

                            <Button text="Changer le mot de passe"
                                    onAction="#handleChangePassword"
                                    style="-fx-background-color: #E24B4A;
                                           -fx-text-fill: white; -fx-font-size: 13;
                                           -fx-font-weight: bold; -fx-background-radius: 6;
                                           -fx-cursor: hand; -fx-padding: 10 20;"/>
                        </VBox>

                    </VBox>

                    <!-- ── RIGHT COLUMN ────────────────────────────── -->
                    <VBox spacing="16" prefWidth="300">

                        <!-- Section 3: Financial Preferences -->
                        <VBox spacing="14"
                              style="-fx-background-color: white;
                                     -fx-border-color: #eeeeee; -fx-border-width: 0.5;
                                     -fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-padding: 20 24;">

                            <Label text="Preferences financieres"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #222222;"/>

                            <VBox spacing="4">
                                <Label text="Revenu mensuel (TND)"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <TextField fx:id="incomeField" promptText="ex: 3000"
                                           style="-fx-pref-height: 36; -fx-font-size: 13;
                                                  -fx-background-radius: 6; -fx-border-radius: 6;
                                                  -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                                <Label fx:id="incomeError" text=""
                                       style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                            </VBox>

                            <VBox spacing="4">
                                <Label text="Devise preferee"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <ComboBox fx:id="currencyCombo" maxWidth="Infinity"
                                          style="-fx-pref-height: 36; -fx-font-size: 13;
                                                 -fx-background-radius: 6;"/>
                            </VBox>

                            <Button text="Sauvegarder les preferences"
                                    onAction="#handleSavePreferences"
                                    style="-fx-background-color: #1D9E75;
                                           -fx-text-fill: white; -fx-font-size: 13;
                                           -fx-font-weight: bold; -fx-background-radius: 6;
                                           -fx-cursor: hand; -fx-padding: 10 20;
                                           -fx-max-width: Infinity;"/>
                        </VBox>

                        <!-- Section 4: Language -->
                        <VBox spacing="14"
                              style="-fx-background-color: white;
                                     -fx-border-color: #eeeeee; -fx-border-width: 0.5;
                                     -fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-padding: 20 24;">

                            <Label text="Langue de l'interface"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #222222;"/>

                            <ComboBox fx:id="languageCombo" maxWidth="Infinity"
                                      style="-fx-pref-height: 36; -fx-font-size: 13;
                                             -fx-background-radius: 6;"/>

                            <Button text="Sauvegarder la langue"
                                    onAction="#handleSaveLanguage"
                                    style="-fx-background-color: #EF9F27;
                                           -fx-text-fill: white; -fx-font-size: 13;
                                           -fx-font-weight: bold; -fx-background-radius: 6;
                                           -fx-cursor: hand; -fx-padding: 10 20;
                                           -fx-max-width: Infinity;"/>
                        </VBox>

                        <!-- Section 5: Account info -->
                        <VBox spacing="10"
                              style="-fx-background-color: #f0f7ff;
                                     -fx-border-color: #B5D4F4; -fx-border-width: 0.5;
                                     -fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-padding: 16 20;">
                            <Label text="Informations du compte"
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #0C447C;"/>
                            <HBox spacing="8">
                                <Label text="Role :"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <Label fx:id="roleLabel"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #185FA5;"/>
                            </HBox>
                            <HBox spacing="8">
                                <Label text="Membre depuis :"
                                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                                <Label fx:id="memberSinceLabel"
                                       style="-fx-font-size: 12; -fx-text-fill: #185FA5;"/>
                            </HBox>
                        </VBox>

                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
