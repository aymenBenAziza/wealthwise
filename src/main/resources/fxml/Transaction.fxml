<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wealthwise.controllers.TransactionController"
            style="-fx-background-color: #f4f5f7;">

    <!-- ── TOP BAR ──────────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #185FA5; -fx-padding: 14 28 14 28;">

            <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                <Label text="WEALTHWISE"
                       style="-fx-font-size: 11; -fx-font-weight: bold;
                              -fx-text-fill: #B5D4F4; -fx-letter-spacing: 2;"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button text="Tableau de bord" onAction="#goToDashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-font-size: 12;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14;"/>
                <Button text="Transactions"
                        style="-fx-background-color: white; -fx-text-fill: #185FA5;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 14;"/>
                <Button text="Profil" onAction="#goToProfile"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                           -fx-text-fill: white; -fx-font-size: 12;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-padding: 6 14;"/>
                <Button text="Deconnexion" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #B5D4F4;
                               -fx-font-size: 12; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 6 10; -fx-border-color: transparent;">
                    <HBox.margin><Insets left="8"/></HBox.margin>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ── BODY ─────────────────────────────────────────────────────── -->
    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Page title -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Transactions"
                           style="-fx-font-size: 20; -fx-font-weight: bold;
                                  -fx-text-fill: #222222;"/>
                    <Label text="Ajoutez et gerez vos revenus et depenses"
                           style="-fx-font-size: 13; -fx-text-fill: #888888;"/>
                </VBox>
                <!-- Manage categories button -->
                <Button text="Gerer les categories" onAction="#handleManageCategories"
                        style="-fx-background-color: #E6F1FB; -fx-text-fill: #0C447C;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;"/>
            </HBox>

            <!-- ── FORM CARD ───────────────────────────────────────── -->
            <VBox spacing="12"
                  style="-fx-background-color: white;
                         -fx-border-color: #eeeeee; -fx-border-width: 0.5;
                         -fx-background-radius: 12; -fx-border-radius: 12;
                         -fx-padding: 18 22;">

                <Label text="Nouvelle transaction"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333333;"/>

                <HBox spacing="12" alignment="BOTTOM_LEFT">

                    <!-- Montant -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Montant (TND)"
                               style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                        <TextField fx:id="amountField" promptText="0.00"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                        <Label fx:id="amountError" text=""
                               style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                    </VBox>

                    <!-- Type -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Type"
                               style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                        <ComboBox fx:id="typeCombo" maxWidth="Infinity"
                                  promptText="-- Type --"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;
                                         -fx-background-radius: 6;"/>
                        <Label fx:id="typeError" text=""
                               style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                    </VBox>

                    <!-- Categorie + Add button -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Categorie"
                               style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                        <HBox spacing="6">
                            <ComboBox fx:id="categoryCombo" HBox.hgrow="ALWAYS"
                                      maxWidth="Infinity" promptText="-- Categorie --"
                                      style="-fx-pref-height: 36; -fx-font-size: 13;
                                             -fx-background-radius: 6;"/>
                            <Button text="+" onAction="#handleAddCategory"
                                    style="-fx-pref-height: 36; -fx-pref-width: 36;
                                           -fx-background-color: #185FA5;
                                           -fx-text-fill: white; -fx-font-size: 16;
                                           -fx-font-weight: bold; -fx-background-radius: 6;
                                           -fx-cursor: hand;">
                                <tooltip><Tooltip text="Ajouter une categorie"/></tooltip>
                            </Button>
                        </HBox>
                        <Label fx:id="categoryError" text=""
                               style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                    </VBox>

                    <!-- Date -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Date"
                               style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                        <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                    style="-fx-pref-height: 36; -fx-font-size: 13;
                                           -fx-background-radius: 6;"/>
                        <Label fx:id="dateError" text=""
                               style="-fx-text-fill: #E24B4A; -fx-font-size: 11;"/>
                    </VBox>

                    <!-- Note -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Note"
                               style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                        <TextField fx:id="noteField" promptText="Description (optionnel)"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-background-radius: 6; -fx-border-radius: 6;
                                          -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
                        <Label text="" style="-fx-font-size: 11;"/>
                    </VBox>

                    <!-- Add button -->
                    <VBox alignment="BOTTOM_CENTER">
                        <Button text="+ Ajouter" onAction="#handleAdd"
                                style="-fx-pref-height: 36; -fx-background-color: #185FA5;
                                       -fx-text-fill: white; -fx-font-size: 13;
                                       -fx-font-weight: bold; -fx-background-radius: 6;
                                       -fx-cursor: hand; -fx-padding: 0 20;"/>
                        <Label text="" style="-fx-font-size: 11;"/>
                    </VBox>

                </HBox>

                <Label fx:id="messageLabel" text="" wrapText="true"
                       style="-fx-font-size: 12; -fx-background-radius: 6; -fx-padding: 6 12;"/>
            </VBox>

            <!-- ── FILTER + SEARCH ROW ─────────────────────────────── -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Filtrer :"
                       style="-fx-font-size: 12; -fx-text-fill: #555555;"/>
                <ComboBox fx:id="filterCombo" prefWidth="140" onAction="#handleFilter"
                          style="-fx-font-size: 13; -fx-background-radius: 6;"/>
                <Label text="Rechercher :"
                       style="-fx-font-size: 12; -fx-text-fill: #555555;">
                    <HBox.margin><Insets left="12"/></HBox.margin>
                </Label>
                <TextField fx:id="searchField" promptText="Note ou categorie..."
                           prefWidth="220" onKeyReleased="#handleSearch"
                           style="-fx-pref-height: 34; -fx-font-size: 13;
                                  -fx-background-radius: 6; -fx-border-radius: 6;
                                  -fx-border-color: #dddddd; -fx-border-width: 0.5;"/>
            </HBox>

            <!-- ── TABLE CARD ──────────────────────────────────────── -->
            <VBox VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-border-color: #eeeeee; -fx-border-width: 0.5;
                         -fx-background-radius: 12; -fx-border-radius: 12;">
                <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent;
                                  -fx-border-color: transparent;
                                  -fx-table-cell-border-color: #f0f0f0;">
                    <columns>
                        <TableColumn fx:id="noteColumn"     text="Note"      prefWidth="160"/>
                        <TableColumn fx:id="typeColumn"     text="Type"      prefWidth="100"/>
                        <TableColumn fx:id="categoryColumn" text="Categorie" prefWidth="140"/>
                        <TableColumn fx:id="dateColumn"     text="Date"      prefWidth="110"/>
                        <TableColumn fx:id="amountColumn"   text="Montant"   prefWidth="130"/>
                        <TableColumn fx:id="actionColumn"   text="Actions"   prefWidth="180"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucune transaction. Ajoutez-en une ci-dessus."
                               style="-fx-text-fill: #aaaaaa; -fx-font-size: 13;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
